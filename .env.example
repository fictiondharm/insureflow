# InsureFlow — Environment Variables
# Copy this to .env and fill in values after deployment

# Contract addresses (get these from running: npx hardhat run scripts/deploy.ts --network baseSepolia)
NEXT_PUBLIC_STABLECOIN_ADDRESS=
NEXT_PUBLIC_PREMIUM_POOL_ADDRESS=
NEXT_PUBLIC_POLICY_ESCROW_ADDRESS=

# Demo mode: set to "true" to use fake transactions, "false" for real Base Sepolia
NEXT_PUBLIC_DEMO_MODE=true
